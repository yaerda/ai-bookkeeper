<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 12+ system splash: transparent icon, matching background -->
    <style name="Theme.AiBookkeeper.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/splash_bg</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash_transparent</item>
        <item name="windowSplashScreenAnimationDuration">0</item>
        <item name="postSplashScreenTheme">@style/Theme.AiBookkeeper</item>
    </style>
</resources>
