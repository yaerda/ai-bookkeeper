<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="8dp">

    <!-- Row 1: Quick action buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="8dp">

        <Button
            android:id="@+id/btn_text_input"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="✏️ 文字记账"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:background="@android:color/holo_blue_dark" />

        <Button
            android:id="@+id/btn_voice_input"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:text="🎙️ 语音记账"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:background="@android:color/holo_green_dark" />

        <Button
            android:id="@+id/btn_camera_input"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="📷 拍照记账"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:background="@android:color/holo_orange_dark" />
    </LinearLayout>

    <!-- Row 2: Frequent category quick buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <Button
            android:id="@+id/btn_category_food"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginEnd="2dp"
            android:text="🍚 餐饮"
            android:textSize="11sp"
            android:background="?android:attr/selectableItemBackground" />

        <Button
            android:id="@+id/btn_category_transport"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"
            android:text="🚗 交通"
            android:textSize="11sp"
            android:background="?android:attr/selectableItemBackground" />

        <Button
            android:id="@+id/btn_category_coffee"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"
            android:text="☕ 咖啡"
            android:textSize="11sp"
            android:background="?android:attr/selectableItemBackground" />

        <Button
            android:id="@+id/btn_category_shopping"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginStart="2dp"
            android:text="🛒 购物"
            android:textSize="11sp"
            android:background="?android:attr/selectableItemBackground" />
    </LinearLayout>

</LinearLayout>
